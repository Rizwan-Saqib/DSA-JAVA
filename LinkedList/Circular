
class CSLL {
    Node tail;
    Node head;

    class Node {

        int val;
        Node next;

        public Node(int val) {
            this.val = val;

        }

    }
public void insert(int val) {
        Node node = new Node(val);
        if (head == null) {

            head = node;
            tail = node;
            tail.next = head;
            return;
        }
        tail.next = node;
        node.next = head;
        tail = node;

    }
 public void display() {
        Node currhead = head;

        if (head != null) {
            do {
                System.out.print(currhead.val + " --> ");
                currhead = currhead.next;

            } while (currhead != head);

        }

    }
